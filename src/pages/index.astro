---
import BaseLayout from '../layouts/BaseLayout.astro';
import DisclaimerBox from '../components/DisclaimerBox.astro';
import VnIndexChart from '../components/VnIndexChart.astro';
import { getCollection } from 'astro:content';
import { valuationModels } from '../data/valuation-models';

const allMarketViews = await getCollection('market-views');
const allMonthlyViews = await getCollection('monthly-views');

const sortedMarketViews = allMarketViews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestMarketViews = sortedMarketViews.slice(0, 2);
const latestMonthlyView = allMonthlyViews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 1);

const trendData = sortedMarketViews
  .slice()
  .reverse()
  .map((entry) => ({
    time: entry.data.week_end.toISOString().slice(0, 10),
    value: entry.data.vn_index_close,
  }));
const featuredValuations = valuationModels.filter((model) => ['hpg', 'bid'].includes(model.slug));

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });

const formatWeek = (start: Date, end: Date) => {
  const sDay = start.toLocaleDateString('en-GB', { day: '2-digit' });
  const sMon = start.toLocaleDateString('en-GB', { month: 'short' });
  const eDay = end.toLocaleDateString('en-GB', { day: '2-digit' });
  const eMon = end.toLocaleDateString('en-GB', { month: 'short' });
  const eYear = end.toLocaleDateString('en-GB', { year: 'numeric' });
  return sMon === eMon ? `${sDay}-${eDay} ${eMon} ${eYear}` : `${sDay} ${sMon}-${eDay} ${eMon} ${eYear}`;
};

const signedPct = (value: number | null | undefined) =>
  value == null ? 'N/A' : `${value >= 0 ? '+' : ''}${value.toFixed(2)}%`;
---

<BaseLayout
  title="Nguyen Vu Truong Huy | Vietnam Equity Research Portfolio"
  description="Vietnam equity research, valuation modeling, capital markets notes, and downloadable Excel models by Nguyen Vu Truong Huy."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Nguyen Vu Truong Huy",
    "url": "https://truonghuyresearch.xyz",
    "image": "https://truonghuyresearch.xyz/og-image.png",
    "jobTitle": "Finance & Banking Student, CFA Level II Candidate",
    "alumniOf": {
      "@type": "CollegeOrUniversity",
      "name": "University of Economics Ho Chi Minh City",
      "alternateName": "UEH"
    },
    "knowsAbout": ["Equity Research", "Valuation Modeling", "Vietnam Capital Markets", "DCF Analysis", "Financial Modeling"],
    "sameAs": ["https://www.linkedin.com/in/trghuyy/"]
  })} />
  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-end">
      <div class="lg:col-span-8">
        <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest mb-4">
          Vietnam Equity Research Portfolio
        </p>
        <h1 class="font-display-xl-mobile md:font-display-xl text-display-xl-mobile md:text-display-xl text-terminal-accent mb-6">
          Nguyen Vu Truong Huy
        </h1>
        <p class="font-body-lg text-body-lg text-terminal-text mb-5 max-w-3xl border-l-4 border-terminal-accent pl-6">
          Finance & Banking student at UEH and CFA Level II Candidate focused on Vietnam equity research, valuation modeling, capital markets analysis, and downloadable research/models.
        </p>
        <p class="font-headline-sm text-headline-sm text-terminal-accent mb-8 max-w-3xl">
          Open to Equity Research / Capital Markets / Investment Banking internship opportunities.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#valuation" class="inline-flex min-h-12 items-center justify-center gap-2 px-6 py-3 bg-terminal-accent text-terminal-bg font-label-md uppercase text-label-md hover:bg-on-primary hover:text-terminal-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-terminal-accent transition-colors">
            View Valuation <span class="material-symbols-outlined text-[18px]" aria-hidden="true">arrow_downward</span>
          </a>
          <a href="/cv.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex min-h-12 items-center justify-center gap-2 px-6 py-3 border border-terminal-accent text-terminal-accent font-label-md uppercase text-label-md hover:bg-terminal-card focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-terminal-accent transition-colors">
            Download CV <span class="material-symbols-outlined text-[18px]" aria-hidden="true">download</span>
          </a>
          <a href="https://www.linkedin.com/in/trghuyy/" target="_blank" rel="noopener noreferrer" class="inline-flex min-h-12 items-center justify-center gap-2 px-6 py-3 border border-outline-variant text-terminal-text font-label-md uppercase text-label-md hover:border-terminal-accent hover:text-terminal-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-terminal-accent transition-colors">
            Contact / LinkedIn <span class="material-symbols-outlined text-[18px]" aria-hidden="true">north_east</span>
          </a>
        </div>
      </div>

      <div class="lg:col-span-4 border border-terminal-border border-t-2 border-t-terminal-accent bg-terminal-card p-5">
        <div class="space-y-5">
          <div>
            <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">Who</p>
            <p class="font-body-sm text-body-sm text-terminal-text">UEH Finance & Banking student, GPA 3.64/4.00, CFA Level II Candidate.</p>
          </div>
          <div>
            <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">Analyze</p>
            <p class="font-body-sm text-body-sm text-terminal-text">Vietnam equities, banks, industrial issuers, market flows, and valuation scenarios.</p>
          </div>
          <div>
            <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">Current focus</p>
            <p class="font-body-sm text-body-sm text-terminal-text">DCF ranges, peer benchmarking, bank multiples, and assumption checks for Vietnam-listed companies.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <hr class="border-t border-outline-variant" />
  </div>

  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap" id="about">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
      <div class="md:col-span-4">
        <h2 class="font-display-lg text-display-lg text-terminal-accent mb-2">Background</h2>
        <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest">Profile</p>
      </div>
      <div class="md:col-span-8">
        <div class="space-y-5 max-w-3xl">
          <p class="font-body-md text-body-md text-terminal-text">
            I am a Finance & Banking student at the University of Economics Ho Chi Minh City (UEH), a CFA Level II Candidate, and currently hold a GPA of 3.64/4.00.
          </p>
          <p class="font-body-md text-body-md text-terminal-text">
            My work focuses on Vietnam equity research, valuation modeling, and capital markets analysis. I use Excel, Power BI, and Stata to organize data, test assumptions, and present valuation ranges clearly.
          </p>
          <p class="font-body-md text-body-md text-terminal-text">
            At Hoan Loc Viet, I worked with financial data, reporting, and analysis workflows. This portfolio collects the research notes and model files I am using to build a clearer analyst track record.
          </p>
        </div>

        <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {['Financial Modeling', 'Equity Valuation', 'Market Research', 'Data Analytics'].map((skill) => (
            <div class="border border-terminal-border bg-terminal-card p-4">
              <p class="font-label-md uppercase text-label-md text-terminal-accent">{skill}</p>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap gap-2">
          <span class="inline-block bg-terminal-card border border-outline-variant px-3 py-1 font-label-md uppercase text-label-md text-terminal-text">CFA Level II Candidate</span>
          <span class="inline-block bg-terminal-card border border-outline-variant px-3 py-1 font-label-md uppercase text-label-md text-terminal-text">Finance & Banking, UEH</span>
          <span class="inline-block bg-terminal-card border border-outline-variant px-3 py-1 font-label-md uppercase text-label-md text-terminal-text">GPA 3.64/4.00</span>
          <span class="inline-block bg-terminal-card border border-outline-variant px-3 py-1 font-label-md uppercase text-label-md text-terminal-text">Excel</span>
          <span class="inline-block bg-terminal-card border border-outline-variant px-3 py-1 font-label-md uppercase text-label-md text-terminal-text">Power BI</span>
          <span class="inline-block bg-terminal-card border border-outline-variant px-3 py-1 font-label-md uppercase text-label-md text-terminal-text">Stata</span>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <hr class="border-t border-outline-variant" />
  </div>

  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap" id="valuation">
    <div class="mb-8 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <h2 class="font-display-lg text-display-lg text-terminal-accent mb-2">Valuation</h2>
        <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest">Company models and downloadable workbooks</p>
      </div>
      <a href="/research" class="inline-flex min-h-12 items-center justify-center gap-2 border border-terminal-accent px-5 py-3 font-label-md uppercase text-label-md text-terminal-accent hover:bg-terminal-accent hover:text-terminal-bg transition-colors">
        Open Valuation Page <span class="material-symbols-outlined text-[16px]" aria-hidden="true">arrow_forward</span>
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
      <a href="/research" class="group border border-terminal-accent border-t-4 border-t-terminal-accent bg-terminal-card p-5 hover:bg-terminal-bg transition-colors">
        <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-3">Valuation hub</p>
        <h3 class="font-headline-md text-headline-md text-terminal-accent mb-4 group-hover:text-on-primary transition-colors">All published valuation work</h3>
        <p class="font-body-sm text-body-sm text-terminal-text mb-5">
          Review DCF outputs, comparable analysis, transaction work, assumptions, download cards, and model limitations in one place.
        </p>
        <span class="inline-flex items-center gap-2 font-label-md uppercase text-label-md text-terminal-accent">
          Go to valuation <span class="material-symbols-outlined text-[16px]" aria-hidden="true">north_east</span>
        </span>
      </a>

      {featuredValuations.map((model) => (
        <a href={`/research/${model.slug}`} class="group border border-terminal-border border-t-2 border-t-terminal-accent bg-terminal-card p-5 hover:border-terminal-accent transition-colors">
          <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
            <span class="border border-outline-variant bg-terminal-bg px-2 py-1 font-label-md uppercase text-label-md text-terminal-accent">{model.ticker}</span>
            <span class="font-label-data text-label-data text-on-surface-variant">{model.downloads.length} files</span>
          </div>
          <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-2">{model.sector}</p>
          <h3 class="font-headline-sm text-headline-sm text-terminal-accent mb-3 group-hover:text-on-primary transition-colors">{model.company}</h3>
          <p class="font-body-sm text-body-sm text-terminal-text mb-4">{model.outputRange ?? model.report.stance}</p>
          <div class="flex flex-wrap gap-2">
            {model.methods.map((method) => (
              <span class="border border-outline-variant bg-terminal-bg px-2 py-1 font-label-md uppercase text-label-md text-terminal-text">{method}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <hr class="border-t border-outline-variant" />
  </div>

  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap" id="market-views">
    <div class="mb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <h2 class="font-display-lg text-display-lg text-terminal-accent mb-2">Market Views</h2>
        <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest">Weekly and monthly notes</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 w-full md:w-auto">
        <a href="/market-views" class="inline-flex min-h-12 items-center justify-center gap-2 border border-terminal-accent bg-terminal-bg px-4 py-3 font-label-md uppercase text-label-md text-terminal-accent hover:bg-terminal-card transition-colors">
          <span class="material-symbols-outlined text-[18px]" aria-hidden="true">view_week</span>
          Weekly Notes
        </a>
        <a href="/monthly-views" class="inline-flex min-h-12 items-center justify-center gap-2 bg-terminal-accent px-4 py-3 font-label-md uppercase text-label-md text-terminal-bg hover:bg-on-primary hover:text-terminal-accent transition-colors">
          <span class="material-symbols-outlined text-[18px]" aria-hidden="true">calendar_month</span>
          Monthly Notes
        </a>
      </div>
    </div>

    {trendData.length > 0 && (
      <div class="mb-8">
        <VnIndexChart trendData={trendData} label="VN-INDEX WEEKLY TREND" />
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
      {latestMarketViews.map((entry) => (
        <a href={`/market-views/${entry.slug}`} class="group bg-terminal-card border border-terminal-border border-t-2 border-t-terminal-accent p-5 hover:border-terminal-accent transition-colors">
          <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
            <span class="border border-terminal-accent bg-terminal-bg px-3 py-2 font-label-md uppercase text-label-md text-terminal-accent">Weekly Market View</span>
            <span class="font-mono-data text-mono-data text-on-surface-variant">{formatWeek(entry.data.week_start, entry.data.week_end)}</span>
          </div>
          <h3 class="font-headline-sm text-headline-sm text-terminal-accent mb-4 group-hover:text-on-primary transition-colors">{entry.data.title}</h3>
          <div class="grid grid-cols-2 gap-3 border-t border-outline-variant pt-4">
            <div>
              <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">VN-Index</p>
              <p class="font-mono-data text-mono-data text-terminal-text">{entry.data.vn_index_close.toLocaleString('en-US', { minimumFractionDigits: 2 })}</p>
            </div>
            <div>
              <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">Weekly change</p>
              <p class:list={['font-mono-data text-mono-data', entry.data.vn_index_weekly_change_pct >= 0 ? 'text-tertiary' : 'text-error']}>{signedPct(entry.data.vn_index_weekly_change_pct)}</p>
            </div>
          </div>
        </a>
      ))}

      {latestMonthlyView.map((entry) => (
        <a href={`/monthly-views/${entry.slug}`} class="group bg-terminal-card border border-terminal-accent border-t-4 border-t-terminal-accent p-5 hover:border-terminal-accent transition-colors">
          <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
            <span class="bg-terminal-accent px-3 py-2 font-label-md uppercase text-label-md text-terminal-bg">Monthly Market View</span>
            <span class="font-mono-data text-mono-data text-on-surface-variant">{formatDate(entry.data.date)}</span>
          </div>
          <h3 class="font-headline-sm text-headline-sm text-terminal-accent mb-4 group-hover:text-on-primary transition-colors">{entry.data.title}</h3>
          <div class="grid grid-cols-2 gap-3 border-t border-outline-variant pt-4">
            <div>
              <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">VN-Index</p>
              <p class="font-mono-data text-mono-data text-terminal-text">{entry.data.vn_index_close.toLocaleString('en-US', { minimumFractionDigits: 2 })}</p>
            </div>
            <div>
              <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">Monthly change</p>
              <p class:list={['font-mono-data text-mono-data', entry.data.vn_index_monthly_change_pct >= 0 ? 'text-tertiary' : 'text-error']}>{signedPct(entry.data.vn_index_monthly_change_pct)}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto pb-section-gap">
    <DisclaimerBox />
  </section>
</BaseLayout>
