---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found | Truong Huy Research" description="The page you're looking for doesn't exist.">
  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap flex flex-col items-center justify-center min-h-[60vh] text-center">
    <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest mb-4">Error 404</p>
    <h1 class="font-display-xl-mobile md:font-display-xl text-display-xl-mobile md:text-display-xl text-terminal-accent mb-6">
      Page Not Found
    </h1>
    <p class="font-body-lg text-body-lg text-terminal-text mb-10 max-w-xl">
      The page you requested does not exist or has been moved. Use the links below to navigate back.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/" class="inline-flex min-h-12 items-center justify-center px-6 py-3 bg-terminal-accent text-terminal-bg font-label-md uppercase text-label-md hover:bg-on-primary hover:text-terminal-accent transition-colors">
        Home
      </a>
      <a href="/research" class="inline-flex min-h-12 items-center justify-center px-6 py-3 border border-terminal-accent text-terminal-accent font-label-md uppercase text-label-md hover:bg-terminal-card transition-colors">
        Valuation
      </a>
      <a href="/market-views" class="inline-flex min-h-12 items-center justify-center px-6 py-3 border border-outline-variant text-terminal-text font-label-md uppercase text-label-md hover:border-terminal-accent hover:text-terminal-accent transition-colors">
        Market Views
      </a>
    </div>
  </section>
</BaseLayout>
