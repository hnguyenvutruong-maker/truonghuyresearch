---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const research = await getCollection('research');
  return research.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = entry.data.date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });

const recColor: Record<string, string> = {
  BUY: 'text-tertiary',
  SELL: 'text-error',
  HOLD: 'text-on-surface-variant',
  NEUTRAL: 'text-on-surface-variant',
};
const accentColor = entry.data.recommendation === 'BUY' ? 'bg-tertiary' : entry.data.recommendation === 'SELL' ? 'bg-error' : 'bg-terminal-accent';
---
<BaseLayout title={entry.data.title}>
  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap">
    <!-- Breadcrumb -->
    <a href="/research" class="font-label-md uppercase text-label-md text-on-surface-variant hover:text-terminal-accent transition-colors">
      &larr; All Research
    </a>

    <!-- Key Findings Card -->
    <div class="bg-terminal-card border border-terminal-border border-t-2 border-t-terminal-accent p-6 mt-6 relative overflow-hidden">
      <div class:list={["absolute left-0 top-0 bottom-0 w-1", accentColor]}></div>
      <div class="ml-2 grid grid-cols-1 md:grid-cols-4 gap-gutter">
        <div>
          <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">TICKER</p>
          <p class="font-headline-md text-headline-md text-terminal-accent">{entry.data.ticker}</p>
        </div>
        <div>
          <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">RECOMMENDATION</p>
          <p class:list={["font-headline-md text-headline-md", recColor[entry.data.recommendation]]}>{entry.data.recommendation}</p>
        </div>
        {entry.data.target_price_vnd && (
          <div>
            <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">TARGET PRICE</p>
            <p class="font-mono-data text-mono-data text-terminal-accent text-[24px] leading-[1.4]">{entry.data.target_price_vnd.toLocaleString('en-US')} VND</p>
          </div>
        )}
        <div>
          <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">DATE</p>
          <p class="font-headline-md text-headline-md text-terminal-accent">{formattedDate}</p>
        </div>
      </div>
      <!-- Tags -->
      <div class="ml-2 mt-4 flex flex-wrap gap-2">
        <span class="inline-block bg-terminal-card border border-outline-variant px-3 py-1 font-label-md uppercase text-label-md text-terminal-text">{entry.data.sector}</span>
        {entry.data.pdf_path && (
          <a href={entry.data.pdf_path} class="inline-block bg-terminal-accent px-3 py-1 font-label-md uppercase text-label-md text-terminal-bg hover:bg-on-primary transition-colors">Download PDF</a>
        )}
        {entry.data.xlsx_path && (
          <a href={entry.data.xlsx_path} class="inline-block bg-terminal-card border border-terminal-accent px-3 py-1 font-label-md uppercase text-label-md text-terminal-accent hover:bg-terminal-accent hover:text-terminal-bg transition-colors">Download Model</a>
        )}
      </div>
    </div>

    <!-- Divider -->
    <div class="mt-10">
      <hr class="border-t border-outline-variant" />
    </div>

    <!-- Article Content -->
    <article class="mt-10">
      <h1 class="font-display-xl-mobile md:font-display-xl text-display-xl-mobile md:text-display-xl text-terminal-accent mb-6">{entry.data.title}</h1>
      <div class="prose max-w-none font-body-md text-body-md text-terminal-text mt-6
        prose-headings:text-terminal-accent
        prose-a:text-terminal-accent
        prose-code:bg-terminal-card
        prose-code:text-terminal-accent
        prose-hr:border-outline-variant
        prose-strong:text-terminal-accent
        prose-p:text-terminal-text
        prose-li:text-terminal-text
      ">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
