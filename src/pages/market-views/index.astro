---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allViews = await getCollection('market-views');
const sortedViews = allViews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const entryCount = sortedViews.length;

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
}

const toneDotMap: Record<string, string> = {
  positive: 'bg-term-up',
  negative: 'bg-term-down',
  neutral: 'bg-term-accent',
};
---
<BaseLayout title="Market Commentary — [YOUR_FULL_NAME]">
  <h1 class="text-lg font-semibold border-l-2 border-term-accent pl-3">MARKET COMMENTARY</h1>
  <p class="font-mono text-xs text-term-muted mt-2">{entryCount} entries · Updated on trading days</p>

  <div class="mt-8">
    {sortedViews.map((entry, i) => {
      const dotClass = toneDotMap[entry.data.session_tone];
      const changeColor = entry.data.vn_index_change_pct >= 0 ? 'text-term-up' : 'text-term-down';
      const changeSign = entry.data.vn_index_change_pct >= 0 ? '+' : '';
      const changeText = `${changeSign}${entry.data.vn_index_change_pct.toFixed(2)}%`;
      const isLast = i === sortedViews.length - 1;
      return (
        <a href={`/market-views/${entry.slug}`} class:list={["flex items-center gap-3 py-3 hover:bg-term-surface transition-colors", isLast ? '' : 'border-b border-term-border']}>
          <span class="font-mono text-xs text-term-muted w-28 shrink-0">{formatDate(entry.data.date)}</span>
          <span class:list={["w-2 h-2 rounded-full shrink-0", dotClass]} />
          <span class="font-mono text-sm text-term-text shrink-0">{entry.data.vn_index_close.toLocaleString('en-US', { minimumFractionDigits: 2 })}</span>
          <span class:list={["font-mono text-xs shrink-0", changeColor]}>{changeText}</span>
          <span class="text-sm text-term-muted truncate flex-1">{entry.data.title}</span>
        </a>
      );
    })}
  </div>
</BaseLayout>