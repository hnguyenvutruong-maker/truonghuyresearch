---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allResearch = await getCollection('research');
const sortedResearch = allResearch.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Equity Research — NVTH Capital Markets">
  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap">
    <!-- Page Header -->
    <header class="mb-section-gap max-w-3xl border-b border-outline-variant pb-8">
      <h1 class="font-display-xl-mobile md:font-display-xl text-display-xl-mobile md:text-display-xl text-terminal-accent mb-4">Equity Research</h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant">
        In-depth sector analysis, thematic deep dives, and fundamental company reports. Uncompromising data rigor for institutional decision-making.
      </p>
    </header>

    <!-- Section header (latest reports) -->
    <div class="flex items-center justify-between border-b border-terminal-accent pb-2 mb-4">
      <h2 class="font-label-md uppercase text-label-md text-terminal-accent tracking-widest">Latest Reports</h2>
      <span class="font-label-data text-label-data text-on-surface-variant">{sortedResearch.length} {sortedResearch.length === 1 ? 'report' : 'reports'}</span>
    </div>

    {sortedResearch.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
        {sortedResearch.map((entry) => (
          <article class="group bg-terminal-card border border-terminal-border border-t-2 border-t-terminal-accent p-6 hover:border-terminal-accent transition-colors cursor-pointer flex flex-col h-full">
            <a href={`/research/${entry.slug}`} class="contents">
              <div class="flex justify-between items-start mb-6">
                <span class="inline-block px-2 py-1 bg-terminal-bg border border-outline-variant font-label-md uppercase text-label-md text-terminal-accent">{entry.data.ticker}</span>
                <span class="font-mono-data text-mono-data text-terminal-text">{entry.data.date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })}</span>
              </div>
              <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-2">{entry.data.sector}</p>
              <h3 class="font-headline-md text-headline-md text-terminal-accent mb-4 group-hover:text-on-primary transition-colors">
                {entry.data.title}
              </h3>
              <p class="font-body-sm text-body-sm text-terminal-text mb-6 flex-grow line-clamp-3">
                {entry.data.summary}
              </p>
              <div class="flex items-center gap-2 font-label-md uppercase text-label-md text-terminal-accent mt-auto">
                Read Full Note <span class="material-symbols-outlined text-[16px]">north_east</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="border border-dashed border-outline-variant p-12 text-center">
        <p class="font-body-md text-body-md text-on-surface-variant">Research reports will appear here.</p>
      </div>
    )}
  </section>
</BaseLayout>
