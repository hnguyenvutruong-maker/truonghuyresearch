---
import BaseLayout from '../layouts/BaseLayout.astro';
import DisclaimerBox from '../components/DisclaimerBox.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { valuationGroups, valuationModels, type ValuationGroupId } from '../data/valuation-models';

const downloadCount = valuationModels.reduce((total, model) => total + model.downloads.length, 0);
const methodPageConfig: Array<{ id: ValuationGroupId; href: string }> = [
  { id: 'dcf', href: '/research/dcf' },
  { id: 'comparable', href: '/research/comparable-analysis' },
  { id: 'transaction-lbo', href: '/research/precedent-transactions-lbo' },
];
const methodLinks = methodPageConfig.map((item) => {
  const group = valuationGroups.find((valuationGroup) => valuationGroup.id === item.id);
  const modelCount = valuationModels.filter((model) => model.valuationNotes.some((note) => note.groups.includes(item.id))).length;
  return { ...item, group, modelCount };
});
---

<BaseLayout
  title="Valuation - Nguyen Vu Truong Huy"
  description="Selected Vietnam equity valuation work, capital markets notes, and downloadable model files."
>
  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap">
    <header class="mb-section-gap max-w-4xl border-b border-outline-variant pb-8">
      <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest mb-3">Valuation portfolio</p>
      <h1 class="font-display-xl-mobile md:font-display-xl text-display-xl-mobile md:text-display-xl text-terminal-accent mb-4">
        Valuation
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant">
        Company valuation work, model assumptions, output ranges, and downloadable files prepared for academic portfolio demonstration.
      </p>
      <div class="mt-6 flex flex-wrap gap-3 font-label-data text-label-data text-on-surface-variant">
        <span class="border border-outline-variant px-3 py-1">{valuationModels.length} published issuers</span>
        <span class="border border-outline-variant px-3 py-1">{downloadCount} downloadable files</span>
      </div>
    </header>

    <div class="mb-8 grid grid-cols-2 border border-outline-variant bg-terminal-card" role="tablist" aria-label="Valuation views">
      <button
        type="button"
        data-valuation-tab="company"
        class="min-h-12 border-r border-outline-variant bg-terminal-accent px-4 py-3 font-label-md uppercase text-label-md text-terminal-bg transition-colors"
        aria-selected="true"
      >
        Company
      </button>
      <button
        type="button"
        data-valuation-tab="method"
        class="min-h-12 bg-terminal-card px-4 py-3 font-label-md uppercase text-label-md text-terminal-text hover:text-terminal-accent transition-colors"
        aria-selected="false"
      >
        Method
      </button>
    </div>

    <section data-valuation-view="company">
      <div class="mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4 border-b border-terminal-accent pb-3">
        <div>
          <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest mb-2">By ticker</p>
          <h2 class="font-display-lg text-display-lg text-terminal-accent">Company Valuation Reports</h2>
        </div>
        <p class="font-body-sm text-body-sm text-on-surface-variant max-w-2xl md:text-right">
          Use this view when you want to start from a company or ticker first.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter">
        {valuationModels.map((model) => (
          <ProjectCard project={model} />
        ))}
      </div>
    </section>

    <section data-valuation-view="method" class="hidden">
      <div class="mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4 border-b border-terminal-accent pb-3">
        <div>
          <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest mb-2">By valuation method</p>
          <h2 class="font-display-lg text-display-lg text-terminal-accent">Method Pages</h2>
        </div>
        <p class="font-body-sm text-body-sm text-on-surface-variant max-w-2xl md:text-right">
          Use this view when you want to compare workbooks and reports built with the same valuation method.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
        {methodLinks.map(({ group, href, modelCount }) => group && (
          <a href={href} class="group border border-terminal-border border-t-2 border-t-terminal-accent bg-terminal-card p-5 hover:border-terminal-accent transition-colors">
            <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-2">{group.eyebrow}</p>
            <h3 class="font-headline-md text-headline-md text-terminal-accent mb-4 group-hover:text-on-primary transition-colors">{group.title}</h3>
            <p class="font-body-sm text-body-sm text-terminal-text mb-5">{group.description}</p>
            <div class="flex items-center justify-between border-t border-outline-variant pt-4">
              <span class="font-label-data text-label-data text-on-surface-variant">{modelCount} reports</span>
              <span class="inline-flex items-center gap-2 font-label-md uppercase text-label-md text-terminal-accent">
                Open page <span class="material-symbols-outlined text-[16px]" aria-hidden="true">arrow_forward</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </section>

  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto pb-section-gap">
    <DisclaimerBox />
  </section>

  <script>
    const tabs = Array.from(document.querySelectorAll('[data-valuation-tab]'));
    const panels = Array.from(document.querySelectorAll('[data-valuation-view]'));
    const activeClasses = ['bg-terminal-accent', 'text-terminal-bg'];
    const inactiveClasses = ['bg-terminal-card', 'text-terminal-text'];

    const setValuationView = (view: string) => {
      panels.forEach((panel) => {
        panel.classList.toggle('hidden', panel.getAttribute('data-valuation-view') !== view);
      });

      tabs.forEach((tab) => {
        const active = tab.getAttribute('data-valuation-tab') === view;
        tab.setAttribute('aria-selected', String(active));
        tab.classList.toggle('hover:text-terminal-accent', !active);
        activeClasses.forEach((className) => tab.classList.toggle(className, active));
        inactiveClasses.forEach((className) => tab.classList.toggle(className, !active));
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const view = tab.getAttribute('data-valuation-tab');
        if (view) setValuationView(view);
      });
    });
  </script>
</BaseLayout>
