---
import BaseLayout from '../layouts/BaseLayout.astro';
import { valuationModels } from '../data/valuation-models';

const downloadCount = valuationModels.reduce((total, model) => total + model.downloads.length, 0);
---
<BaseLayout title="Equity Valuation Models - NVTH Capital Markets">
  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap">
    <header class="mb-section-gap max-w-3xl border-b border-outline-variant pb-8">
      <h1 class="font-display-xl-mobile md:font-display-xl text-display-xl-mobile md:text-display-xl text-terminal-accent mb-4">Equity Valuation Models</h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant">
        Downloadable Excel models by ticker, mapped to the valuation method best suited for the company and transaction context.
      </p>
    </header>

    <div class="flex items-center justify-between border-b border-terminal-accent pb-2 mb-4">
      <h2 class="font-label-md uppercase text-label-md text-terminal-accent tracking-widest">Model Library</h2>
      <span class="font-label-data text-label-data text-on-surface-variant">{valuationModels.length} issuers / {downloadCount} downloads</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter">
      {valuationModels.map((model) => (
        <article class="bg-terminal-card border border-terminal-border border-t-2 border-t-terminal-accent p-6 hover:border-terminal-accent transition-colors flex flex-col h-full">
          <div class="flex justify-between items-start gap-4 mb-6">
            <div>
              <span class="inline-block px-2 py-1 bg-terminal-bg border border-outline-variant font-label-md uppercase text-label-md text-terminal-accent mb-3">{model.ticker}</span>
              <h3 class="font-headline-md text-headline-md text-terminal-accent">{model.company}</h3>
            </div>
            <span class="font-label-data text-label-data text-on-surface-variant whitespace-nowrap">{model.downloads.length} {model.downloads.length === 1 ? 'file' : 'files'}</span>
          </div>

          <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-3">{model.sector}</p>
          <p class="font-body-sm text-body-sm text-terminal-text mb-5 flex-grow">{model.summary}</p>

          <div class="flex flex-wrap gap-2 mb-5">
            {model.methods.map((method) => (
              <span class="inline-block bg-terminal-bg border border-outline-variant px-3 py-1 font-label-md uppercase text-label-md text-terminal-text">{method}</span>
            ))}
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
            {model.downloads.map((download) => (
              <a
                href={download.href}
                download
                class="group min-h-12 inline-flex items-center justify-between gap-3 border border-terminal-accent px-3 py-3 font-label-md uppercase text-label-md text-terminal-accent hover:bg-terminal-accent hover:text-terminal-bg transition-colors"
              >
                <span class="inline-flex items-center gap-2 min-w-0">
                  <span class="material-symbols-outlined text-[18px] shrink-0">download</span>
                  <span class="truncate">{download.label}</span>
                </span>
                <span class="font-label-data text-label-data opacity-80 shrink-0">{download.format}</span>
              </a>
            ))}
          </div>

          <div class="border-t border-outline-variant pt-4">
            <p class="font-label-md uppercase text-label-md text-terminal-accent mb-3">Workbook Structure</p>
            <div class="space-y-3">
              {model.downloads.map((download) => (
                <div>
                  <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
                    <span class="font-label-md uppercase text-label-md text-terminal-text">{download.label}</span>
                    <span class="font-mono-data text-mono-data text-on-surface-variant break-all">{download.sourceTemplate}</span>
                  </div>
                  <p class="font-body-sm text-body-sm text-on-surface-variant">{download.sheets.join(' / ')}</p>
                </div>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="mt-section-gap border border-terminal-border bg-terminal-card p-6">
      <div class="flex items-start gap-4">
        <span class="material-symbols-outlined text-terminal-accent text-[24px]">table_chart</span>
        <div>
          <h2 class="font-headline-sm text-headline-sm text-terminal-accent mb-2">Template Coverage</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
            <div>
              <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">DCF</p>
              <p class="font-body-sm text-body-sm text-terminal-text">Core DCF tab, net working capital schedule, WACC bridge, and two assumption pages.</p>
            </div>
            <div>
              <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">Comparable Analysis</p>
              <p class="font-body-sm text-body-sm text-terminal-text">TargetCo input page, peer company pages, output table, and benchmarking pages.</p>
            </div>
            <div>
              <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">Precedent Transactions</p>
              <p class="font-body-sm text-body-sm text-terminal-text">Acquirer-target input pages, transaction list, and precedent valuation output.</p>
            </div>
            <div>
              <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">LBO</p>
              <p class="font-body-sm text-body-sm text-terminal-text">Transaction summary, operating statements, debt schedule, returns analysis, and financing assumptions.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
