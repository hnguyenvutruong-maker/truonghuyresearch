---
import BaseLayout from '../layouts/BaseLayout.astro';
import { valuationGroups, valuationModels, type ValuationGroupId } from '../data/valuation-models';

const downloadCount = valuationModels.reduce((total, model) => total + model.downloads.length, 0);
const modelsForGroup = (groupId: ValuationGroupId) => valuationModels.filter((model) => model.valuationNotes.some((note) => note.groups.includes(groupId)));
const notesForGroup = (model: (typeof valuationModels)[number], groupId: ValuationGroupId) => model.valuationNotes.filter((note) => note.groups.includes(groupId));
const downloadsForGroup = (model: (typeof valuationModels)[number], groupId: ValuationGroupId) => model.downloads.filter((download) => download.groups.includes(groupId));
---
<BaseLayout title="Equity Valuation Reports - NVTH Capital Markets">
  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap">
    <header class="mb-section-gap max-w-4xl border-b border-outline-variant pb-8">
      <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest mb-3">Equity Research</p>
      <h1 class="font-display-xl-mobile md:font-display-xl text-display-xl-mobile md:text-display-xl text-terminal-accent mb-4">Equity Valuation Reports</h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant">
        Read the valuation logic directly on the site, then download the completed Excel models if you want the workbook detail.
      </p>
      <div class="mt-6 flex flex-wrap gap-3 font-label-data text-label-data text-on-surface-variant">
        <span class="border border-outline-variant px-3 py-1">{valuationModels.length} issuers</span>
        <span class="border border-outline-variant px-3 py-1">{downloadCount} model files</span>
        <span class="border border-outline-variant px-3 py-1">{valuationGroups.length} method groups</span>
      </div>
    </header>

    <div class="space-y-16">
      {valuationGroups.map((group) => {
        const groupedModels = modelsForGroup(group.id);
        return (
          <section id={group.id} class="scroll-mt-24">
            <div class="mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4 border-b border-terminal-accent pb-3">
              <div>
                <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest mb-2">{group.eyebrow}</p>
                <h2 class="font-display-lg text-display-lg text-terminal-accent">{group.title}</h2>
              </div>
              <p class="font-body-sm text-body-sm text-on-surface-variant max-w-2xl md:text-right">{group.description}</p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter">
              {groupedModels.map((model) => {
                const groupNotes = notesForGroup(model, group.id);
                const groupDownloads = downloadsForGroup(model, group.id);
                return (
                  <article class="bg-terminal-card border border-terminal-border border-t-2 border-t-terminal-accent p-6 hover:border-terminal-accent transition-colors flex flex-col h-full">
                    <div class="flex justify-between items-start gap-4 mb-5">
                      <div>
                        <span class="inline-block px-2 py-1 bg-terminal-bg border border-outline-variant font-label-md uppercase text-label-md text-terminal-accent mb-3">{model.ticker}</span>
                        <h3 class="font-headline-md text-headline-md text-terminal-accent">{model.company}</h3>
                      </div>
                      <span class="font-label-data text-label-data text-on-surface-variant whitespace-nowrap">{groupDownloads.length} {groupDownloads.length === 1 ? 'file' : 'files'}</span>
                    </div>

                    <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-3">{model.sector}</p>
                    <p class="font-body-sm text-body-sm text-terminal-text mb-5">{model.summary}</p>

                    <div class="border-y border-outline-variant py-5 mb-5">
                      <p class="font-label-md uppercase text-label-md text-terminal-accent mb-4">Valuation Snapshot</p>
                      <div class="space-y-4">
                        {groupNotes.map((note) => (
                          <div class="border-l-2 border-terminal-accent pl-4">
                            <div class="flex flex-wrap items-baseline justify-between gap-2 mb-2">
                              <span class="font-label-md uppercase text-label-md text-terminal-text">{note.method}</span>
                              <span class="font-mono-data text-mono-data text-terminal-accent">{note.price}</span>
                            </div>
                            <p class="font-body-sm text-body-sm text-on-surface-variant mb-1">
                              <span class="text-terminal-text font-semibold">Assumptions:</span> {note.assumptions}
                            </p>
                            <p class="font-body-sm text-body-sm text-on-surface-variant">
                              <span class="text-terminal-text font-semibold">Result:</span> {note.result}
                            </p>
                          </div>
                        ))}
                      </div>
                    </div>

                    <p class="font-body-sm text-body-sm text-terminal-text mb-5 flex-grow">{model.conclusion}</p>

                    <div class="flex flex-col sm:flex-row gap-3 mt-auto">
                      <a
                        href={`/research/${model.slug}`}
                        class="inline-flex min-h-12 items-center justify-center gap-2 border border-terminal-accent px-4 py-3 font-label-md uppercase text-label-md text-terminal-accent hover:bg-terminal-accent hover:text-terminal-bg transition-colors"
                      >
                        Read Report <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                      </a>
                      {groupDownloads.slice(0, 2).map((download) => (
                        <a
                          href={download.href}
                          download
                          class="inline-flex min-h-12 items-center justify-center gap-2 border border-outline-variant px-4 py-3 font-label-md uppercase text-label-md text-terminal-text hover:border-terminal-accent hover:text-terminal-accent transition-colors"
                        >
                          <span class="material-symbols-outlined text-[18px]">download</span>
                          {download.label}
                        </a>
                      ))}
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        );
      })}
    </div>
  </section>
</BaseLayout>
