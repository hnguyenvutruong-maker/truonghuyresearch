---
import BaseLayout from '../layouts/BaseLayout.astro';
import { portfolioDisclaimer } from '../data/valuation-models';
---

<BaseLayout title="Disclaimer - Nguyen Vu Truong Huy">
  <section class="w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto py-section-gap">
    <a href="/" class="font-label-md uppercase text-label-md text-on-surface-variant hover:text-terminal-accent transition-colors">
      &larr; Back to Home
    </a>

    <header class="mt-6 mb-10 max-w-3xl border-b border-outline-variant pb-8">
      <p class="font-label-md uppercase text-label-md text-on-surface-variant tracking-widest mb-3">Academic portfolio</p>
      <h1 class="font-display-xl-mobile md:font-display-xl text-display-xl-mobile md:text-display-xl text-terminal-accent mb-4">Disclaimer</h1>
    </header>

    <article class="max-w-4xl space-y-6">
      <section class="border border-terminal-border border-t-2 border-t-terminal-accent bg-terminal-card p-6">
        <p class="font-body-lg text-body-lg text-terminal-text">{portfolioDisclaimer}</p>
      </section>
      <p class="font-body-md text-body-md text-terminal-text">
        All models, market views, and equity research notes reflect personal academic work. They do not represent the views, official positions, or investment strategies of any current or past employer.
      </p>
      <p class="font-body-md text-body-md text-terminal-text">
        Readers should verify all assumptions, dates, market data, and workbook formulas independently before using any material for analysis or decision-making.
      </p>
    </article>
  </section>
</BaseLayout>
