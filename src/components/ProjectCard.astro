---
import type { ValuationModel } from '../data/valuation-models';
import StatusBadge from './StatusBadge.astro';

interface Props {
  project: ValuationModel;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const href = `/research/${project.slug}`;
const outputRange =
  project.outputRange ?? project.valuationNotes.map((note) => `${note.method}: ${note.price}`).join('; ');
const fileLabel = `${project.downloads.length} ${project.downloads.length === 1 ? 'file' : 'files'}`;
const primaryDownloadLabel = project.downloads[0]
  ? `Download ${project.downloads[0].modelType ?? project.downloads[0].label}`
  : undefined;
const points =
  project.projectPoints ?? [
    `Built ${project.methods.join(' + ')} analysis.`,
    'Prepared workbook outputs for review.',
    'Explained the valuation range and method limitations.',
  ];
---

<article class:list={['bg-terminal-card border border-terminal-border border-t-2 border-t-terminal-accent p-5 md:p-6 hover:border-terminal-accent transition-colors flex flex-col h-full', compact ? 'gap-4' : 'gap-5']}>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div class="flex flex-wrap items-center gap-2">
      <span class="inline-block bg-terminal-bg border border-outline-variant px-2 py-1 font-label-md uppercase text-label-md text-terminal-accent">
        {project.ticker}
      </span>
      <StatusBadge status={project.status} />
    </div>
    <span class="font-mono-data text-mono-data text-terminal-text">{fileLabel}</span>
  </div>

  <div>
    <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-2">{project.sector}</p>
    <h3 class="font-headline-md text-headline-md text-terminal-accent mb-3">{project.company}</h3>
    <p class="font-body-sm text-body-sm text-terminal-text">{project.summary}</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 border-y border-outline-variant py-4">
    <div>
      <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">Output range</p>
      <p class="font-mono-data text-mono-data text-terminal-accent">{outputRange}</p>
    </div>
    <div>
      <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-1">Last updated</p>
      <p class="font-mono-data text-mono-data text-terminal-text">{project.lastUpdated ?? '2026-06-11'}</p>
    </div>
  </div>

  <div>
    <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-2">Methods used</p>
    <div class="flex flex-wrap gap-2">
      {project.methods.map((method) => (
        <span class="inline-block bg-terminal-bg border border-outline-variant px-2 py-1 font-label-md uppercase text-label-md text-terminal-text">
          {method}
        </span>
      ))}
    </div>
  </div>

  <ul class="space-y-2 flex-grow">
    {points.slice(0, 3).map((point) => (
      <li class="flex gap-3 font-body-sm text-body-sm text-terminal-text">
        <span class="mt-2 block h-1.5 w-1.5 shrink-0 bg-terminal-accent"></span>
        <span>{point}</span>
      </li>
    ))}
  </ul>

  <div class="border-t border-outline-variant pt-4">
    <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-3">{project.disclaimerLabel ?? 'Academic research / not investment advice'}</p>
    <div class="flex flex-col sm:flex-row gap-3">
      <a
        href={href}
        class="inline-flex min-h-12 items-center justify-center gap-2 border border-terminal-accent px-4 py-3 font-label-md uppercase text-label-md text-terminal-accent hover:bg-terminal-accent hover:text-terminal-bg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-terminal-accent transition-colors"
      >
        View Research <span class="material-symbols-outlined text-[16px]" aria-hidden="true">arrow_forward</span>
      </a>
      {project.downloads[0] ? (
        <a
          href={project.downloads[0].href}
          download
          class="inline-flex min-h-12 items-center justify-center gap-2 border border-outline-variant px-4 py-3 font-label-md uppercase text-label-md text-terminal-text hover:border-terminal-accent hover:text-terminal-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-terminal-accent transition-colors"
        >
          <span class="material-symbols-outlined text-[18px]" aria-hidden="true">download</span>
          {primaryDownloadLabel}
        </a>
      ) : null}
    </div>
  </div>
</article>
