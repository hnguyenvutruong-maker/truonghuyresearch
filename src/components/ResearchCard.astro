---
interface Props {
  title: string;
  date: Date;
  ticker: string;
  sector: string;
  recommendation: 'BUY' | 'HOLD' | 'SELL' | 'NEUTRAL';
  summary: string;
  pdf_path?: string;
  slug: string;
}
const { title, date, ticker, sector, recommendation, summary, pdf_path, slug } = Astro.props;

const recStyles: Record<string, string> = {
  BUY: 'text-tertiary',
  SELL: 'text-error',
  HOLD: 'text-on-surface-variant',
  NEUTRAL: 'text-on-surface-variant',
};
const formattedDate = date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
---
<a href={`/research/${slug}`} class="group bg-terminal-card border border-terminal-border border-t-2 border-t-terminal-accent p-6 hover:border-terminal-accent transition-colors cursor-pointer flex flex-col h-full">
  <div class="flex justify-between items-start mb-6">
    <span class="inline-block px-2 py-1 bg-terminal-bg border border-outline-variant font-label-md uppercase text-label-md text-terminal-accent">{ticker}</span>
    <span class:list={["inline-block px-2 py-1 bg-terminal-bg border border-outline-variant font-label-md uppercase text-label-md", recStyles[recommendation]]}>{recommendation}</span>
  </div>
  <p class="font-label-md uppercase text-label-md text-on-surface-variant mb-2">{sector}</p>
  <h3 class="font-headline-md text-headline-md text-terminal-accent mb-4 group-hover:text-on-primary transition-colors">
    {title}
  </h3>
  <p class="font-body-sm text-body-sm text-terminal-text mb-6 flex-grow line-clamp-3">
    {summary}
  </p>
  <div class="flex justify-between items-center mt-auto pt-4 border-t border-outline-variant">
    <span class="font-mono-data text-mono-data text-on-surface-variant">{formattedDate}</span>
    <div class="flex gap-4">
      {pdf_path && <span class="font-label-md uppercase text-label-md text-terminal-accent">PDF <span class="material-symbols-outlined text-[16px] align-middle">north_east</span></span>}
      <span class="flex items-center gap-1 font-label-md uppercase text-label-md text-terminal-accent">
        Read
        <span class="material-symbols-outlined text-[16px]">north_east</span>
      </span>
    </div>
  </div>
</a>
