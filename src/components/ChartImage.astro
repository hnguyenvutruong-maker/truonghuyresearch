---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}
const { src, alt, caption } = Astro.props;
---
<figure class="my-8">
  <div class="bg-terminal-card border border-terminal-border overflow-hidden">
    <img src={src} alt={alt} class="w-full h-auto" loading="lazy" />
  </div>
  {caption && (
    <figcaption class="font-label-md uppercase text-label-md text-on-surface-variant mt-2 text-center">
      {caption}
    </figcaption>
  )}
</figure>
