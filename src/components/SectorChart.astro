---
// Top 5 sectors bar chart, powered by TradingView Lightweight Charts.
// Fetches sector JSON from dataPath, renders vertical bars with category x-axis.

interface Props {
  dataPath: string;       // /charts/sector_data_2026-06-05.json
}
const { dataPath } = Astro.props;
---
<div class="bg-terminal-card border border-terminal-border overflow-hidden">
  <div
    id="sector-chart"
    data-path={dataPath}
    class="w-full"
    style="height: 360px;"
  ></div>
</div>

<script>
  import { createChart } from 'lightweight-charts';

  const BG = '#0d1117';
  const TEXT = '#e6edf3';
  const GRID = '#21262d';
  const BORDER = '#30363d';
  const GREEN = '#84e588';
  const RED = '#ffb4ab';
  const AMBER = '#f0a500';

  const container = document.getElementById('sector-chart');
  if (container) {
    const dataPath = container.getAttribute('data-path') ?? '';
    const handleResize = () => {
      if (container && (container as any)._chart) {
        (container as any)._chart.applyOptions({ width: container.clientWidth });
      }
    };

    fetch(dataPath)
      .then((r) => r.json())
      .then((sectors: Array<{ sector: string; change_pct: number }>) => {
        if (!sectors?.length) return;

        const chart = createChart(container, {
          width: container.clientWidth,
          height: 360,
          layout: {
            background: { color: BG },
            textColor: TEXT,
            fontFamily: 'JetBrains Mono, ui-monospace, SFMono-Regular, monospace',
            fontSize: 12,
          },
          grid: {
            vertLines: { color: GRID, style: 2 },
            horzLines: { color: GRID, style: 2 },
          },
          timeScale: {
            visible: false, // Hide the time scale; we use sectors as categorical x-axis
          },
          rightPriceScale: {
            borderColor: BORDER,
          },
          crosshair: {
            mode: 1,
            vertLine: { color: AMBER, width: 1, style: 3, labelBackgroundColor: AMBER },
            horzLine: { color: AMBER, width: 1, style: 3, labelBackgroundColor: AMBER },
          },
        });

        const barSeries = chart.addBarSeries({
          upColor: GREEN,
          downColor: RED,
          borderUpColor: GREEN,
          borderDownColor: RED,
        });

        // For a categorical x-axis, use the sector index as a string time
        // and overlay the sector name via the tickMarkFormatter below.
        const data = sectors.map((s, i) => ({
          time: String(i),
          value: s.change_pct,
          color: s.change_pct >= 0 ? GREEN : RED,
        }));
        barSeries.setData(data as any);

        // Map index → sector name on the x-axis ticks
        chart.timeScale().applyOptions({
          tickMarkFormatter: (time: any) => {
            const idx = parseInt(String(time), 10);
            return sectors[idx]?.sector ?? '';
          },
        });

        // Price axis: 2-decimal precision
        chart.priceScale('right').applyOptions({
          minMove: 0.01,
        });

        // Add a zero baseline
        barSeries.createPriceLine({
          price: 0,
          color: TEXT,
          lineWidth: 1,
          lineStyle: 0,
          axisLabelVisible: false,
        });

        chart.timeScale().fitContent();

        (container as any)._chart = chart;
        window.addEventListener('resize', handleResize);
      })
      .catch((err) => {
        console.error('Failed to load sector chart data:', err);
        container.innerHTML =
          '<div class="flex items-center justify-center h-full text-on-surface-variant text-sm">Chart data unavailable</div>';
      });
  }
</script>
