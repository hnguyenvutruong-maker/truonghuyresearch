---
// VN-Index weekly candlestick + volume chart, powered by TradingView Lightweight Charts.
// Fetches OHLCV JSON from dataPath, renders interactive Bloomberg-style chart.

interface Props {
  dataPath: string;       // /charts/vnindex_data_2026-06-05.json
  weekHigh: number;
  weekLow: number;
  weekOpen: number;
  weekClose: number;
  changePct: number;
}
const { dataPath } = Astro.props;
---
<div class="bg-terminal-card border border-terminal-border overflow-hidden">
  <div
    id="vnindex-chart"
    data-path={dataPath}
    class="w-full"
    style="height: 480px;"
  ></div>
</div>

<script>
  import { createChart } from 'lightweight-charts';

  const BG = '#0d1117';
  const TEXT = '#e6edf3';
  const GRID = '#21262d';
  const BORDER = '#30363d';
  const GREEN = '#84e588';
  const RED = '#ffb4ab';
  const AMBER = '#f0a500';

  const container = document.getElementById('vnindex-chart');
  if (container) {
    const dataPath = container.getAttribute('data-path') ?? '';
    const handleResize = () => {
      if (container && (container as any)._chart) {
        (container as any)._chart.applyOptions({ width: container.clientWidth });
      }
    };

    fetch(dataPath)
      .then((r) => r.json())
      .then(({ candles, volumes }: { candles: any[]; volumes: any[] }) => {
        if (!candles?.length) return;

        const chart = createChart(container, {
          width: container.clientWidth,
          height: 480,
          layout: {
            background: { color: BG },
            textColor: TEXT,
            fontFamily: 'JetBrains Mono, ui-monospace, SFMono-Regular, monospace',
            fontSize: 12,
          },
          grid: {
            vertLines: { color: GRID, style: 2 },
            horzLines: { color: GRID, style: 2 },
          },
          timeScale: {
            timeVisible: false,
            secondsVisible: false,
            borderColor: BORDER,
            rightOffset: 4,
            barSpacing: 12,
          },
          rightPriceScale: {
            borderColor: BORDER,
            scaleMargins: { top: 0.1, bottom: 0.25 },
          },
          crosshair: {
            mode: 1, // Magnet
            vertLine: { color: AMBER, width: 1, style: 3, labelBackgroundColor: AMBER },
            horzLine: { color: AMBER, width: 1, style: 3, labelBackgroundColor: AMBER },
          },
        });

        // ── Candlestick series ──────────────────────────────────────────────
        const candleSeries = chart.addCandlestickSeries({
          upColor: GREEN,
          downColor: RED,
          borderUpColor: GREEN,
          borderDownColor: RED,
          wickUpColor: GREEN,
          wickDownColor: RED,
        });
        candleSeries.setData(candles);

        // ── Volume histogram (overlay on bottom 20% of price scale) ─────────
        const volSeries = chart.addHistogramSeries({
          priceFormat: { type: 'volume' },
          priceScaleId: '',
          color: GREEN,
        });
        volSeries.priceScale().applyOptions({
          scaleMargins: { top: 0.82, bottom: 0 },
        });
        volSeries.setData(volumes);

        // ── Week summary annotations (right margin tags) ────────────────────
        const lastCandle = candles[candles.length - 1];
        if (lastCandle) {
          candleSeries.createPriceLine({
            price: lastCandle.close,
            color: AMBER,
            lineWidth: 1,
            lineStyle: 2, // Dashed
            axisLabelVisible: true,
            title: `Close ${lastCandle.close.toFixed(2)}`,
          });
        }

        const weekHigh = Math.max(...candles.map((c: any) => c.high));
        const weekLow = Math.min(...candles.map((c: any) => c.low));
        candleSeries.createPriceLine({
          price: weekHigh,
          color: GREEN,
          lineWidth: 1,
          lineStyle: 2,
          axisLabelVisible: true,
          title: `H ${weekHigh.toFixed(2)}`,
        });
        candleSeries.createPriceLine({
          price: weekLow,
          color: RED,
          lineWidth: 1,
          lineStyle: 2,
          axisLabelVisible: true,
          title: `L ${weekLow.toFixed(2)}`,
        });

        chart.timeScale().fitContent();

        // Stash chart handle for resize
        (container as any)._chart = chart;
        window.addEventListener('resize', handleResize);
      })
      .catch((err) => {
        console.error('Failed to load VN-Index chart data:', err);
        container.innerHTML =
          '<div class="flex items-center justify-center h-full text-on-surface-variant text-sm">Chart data unavailable</div>';
      });
  }
</script>
