---
interface Props {
  title: string;
  date: Date;
  vn_index_close: number;
  vn_index_change_pct: number;
  session_tone: 'positive' | 'negative' | 'neutral';
  slug: string;
}
const { title, date, vn_index_close, vn_index_change_pct, session_tone, slug } = Astro.props;

const toneBorder: Record<string, string> = {
  positive: 'border-term-up',
  negative: 'border-term-down',
  neutral: 'border-term-accent',
};
const changeColor = vn_index_change_pct >= 0 ? 'text-term-up' : 'text-term-down';
const formattedDate = date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
---
<a href={`/market-views/${slug}`} class:list={["block bg-term-surface border border-term-border rounded p-4 border-t-2", toneBorder[session_tone], "hover:border-term-link transition-colors cursor-pointer"]}>
  <div class="flex justify-between items-center">
    <span class="font-mono text-xs text-term-muted">{formattedDate}</span>
    <span class="font-mono text-sm text-term-text">{vn_index_close.toLocaleString('en-US', { minimumFractionDigits: 2 })}</span>
  </div>
  <p class="text-sm font-medium text-term-text mt-1">{title}</p>
  <div class="flex justify-end mt-1">
    <span class:list={["font-mono text-xs", changeColor]}>{vn_index_change_pct >= 0 ? '+' : ''}{vn_index_change_pct.toFixed(2)}%</span>
  </div>
</a>